# ===========================================
# BACKEND ENVIRONMENT CONFIGURATION
# Copy this file to .env in the backend folder
# ===========================================

# ===========================================
# DATABASE CONFIGURATION (Neon PostgreSQL)
# ===========================================
# Get your connection string from: https://console.neon.tech/
# Format: postgresql://user:password@ep-xxx-xxx-xxx-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx-xxx-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ===========================================
# JWT CONFIGURATION
# ===========================================
# Generate a secure secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ===========================================
# APPLICATION SETTINGS
# ===========================================
NODE_ENV=development
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ===========================================
# LLM API CONFIGURATION (OpenRouter)
# ===========================================
# Get your FREE API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# API Provider: "openrouter" (default) or "gemini"
API_PROVIDER=openrouter

# Chat Model
CHAT_MODEL=meta-llama/llama-3.2-3b-instruct:free

# ===========================================
# OPTIONAL: Gemini API
# ===========================================
GEMINI_API_KEY=your-gemini-api-key-here

# ===========================================
# EMAIL VERIFICATION & REMINDERS (SMTP)
# ===========================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
FROM_EMAIL=your-email@gmail.com
FRONTEND_URL=http://localhost:3000
