[flake8]
max-line-length = 120
exclude = .venv,venv,__pycache__,*.pyc,node_modules,dist,build,.git
extend-ignore = E203, W503, E712, E722, E402, F821
per-file-ignores =
    # Ignore unused imports in __init__.py files
    __init__.py: F401
    # Ignore unused imports in test files
    test_*.py: F401
    *_test.py: F401
