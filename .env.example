# ===========================================
# ENVIRONMENT CONFIGURATION FOR DOCKER
# Copy this file to .env and fill in your values
# ===========================================

# ===========================================
# DATABASE CONFIGURATION (Neon PostgreSQL)
# ===========================================
# Get your connection string from: https://console.neon.tech/
# Format: postgresql://user:password@ep-xxx-xxx-xxx-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx-xxx-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ===========================================
# JWT CONFIGURATION
# ===========================================
# Generate a secure secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Change this in production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ===========================================
# LLM API CONFIGURATION (OpenRouter)
# ===========================================
# Get your FREE API key from: https://openrouter.ai/keys
# This is required for the AI chat agent to work
OPENROUTER_API_KEY=your-openrouter-api-key-here

# API Provider: "openrouter" (default) or "gemini"
API_PROVIDER=openrouter

# Chat Model - Change this to use different models
# Recommended FREE models with tool calling support:
#   - meta-llama/llama-3.2-3b-instruct:free (default, fast & reliable)
#   - meta-llama/llama-3.1-8b-instruct:free (newer, better reasoning)
#   - google/gemma-3-27b-it:free (powerful, requires Gemini provider)
#   - arcee-ai/trinity-mini:free (fast, good for tools)
#   - mistralai/mistral-7b-instruct:free (balanced performance)
CHAT_MODEL=meta-llama/llama-3.2-3b-instruct:free

# ===========================================
# OPTIONAL: Gemini API (Alternative Provider)
# ===========================================
# If you want to use Google Gemini instead of OpenRouter:
# 1. Set API_PROVIDER=gemini above
# 2. Add your Gemini API key below
# Get key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ===========================================
# EMAIL VERIFICATION & REMINDERS (SMTP)
# ===========================================
# Configure SMTP settings to send verification and reminder emails
# For Gmail: Use App Password (not your regular password)
# 1. Enable 2FA on your Google account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the App Password below

# SMTP Server Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# Email Credentials
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here

# From Email (usually same as SMTP_USERNAME)
FROM_EMAIL=your-email@gmail.com

# Frontend URL for email verification links
FRONTEND_URL=http://localhost:3000

# ===========================================
# DAPR NOTIFICATION SETTINGS
# ===========================================
# Dapr sidecar configuration for scheduled notifications
DAPR_HTTP_PORT=3500
DAPR_GRPC_PORT=50001
DAPR_PUBSUB_NAME=kafka-pubsub

# Notification Settings
NOTIFICATION_ENABLED=true
NOTIFICATION_CHECK_INTERVAL_MINUTES=1

# Recurring Notification Settings
RECURRING_NOTIFICATION_ENABLED=true
RECURRING_CHECK_INTERVAL_MINUTES=5

# ===========================================
# APPLICATION SETTINGS (Usually don't need to change)
# ===========================================
NODE_ENV=production
